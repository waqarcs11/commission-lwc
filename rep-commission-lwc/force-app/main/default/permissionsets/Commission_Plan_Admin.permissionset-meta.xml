<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Commission Plan Admin Access</label>
    <description>Grants access to the Commission Plan Admin LWC and its supporting data. Assign to System Administrators only.</description>

    <!-- Apex class access -->
    <classAccesses>
        <apexClass>CommissionPlanAdminController</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- Commission_Plan_Field_Config__c object permissions -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <object>Commission_Plan_Field_Config__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Representative_Commission__c read access (for field describe) -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Representative_Commission__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
</PermissionSet>
